---
/**
 * The kinetic poster hero: giant staggered ECK / STEIN letters that drop,
 * overshoot and settle, plus the dust-particle canvas and the fallen-stone
 * physics that also carries the BaseLayout cornerstone button into its
 * resting corner. Shared between the DE and EN landing pages so the entrance
 * choreography only has to be written, and tuned, once.
 *
 * Under prefers-reduced-motion (or with JS disabled) the script below never
 * runs: letters, the cornerstone and the baseline rule simply render in
 * their final CSS position, no animation, fully readable immediately.
 */
---

<canvas id="dust" aria-hidden="true"></canvas>
<div class="mid">
  <h1 class="rows" aria-label="Benjamin Eckstein">
    <span class="row" aria-hidden="true">
      <span class="st">E</span><span class="st">C</span><span class="st">K</span>
    </span>
    <span class="row" aria-hidden="true">
      <span class="st">S</span><span class="st">T</span><span class="st">E</span><span class="st">I</span><span
        class="st">N</span
      >
    </span>
    <span class="dict serif" aria-hidden="true" lang="de">der; -s, -e</span>
  </h1>
  <slot />
</div>
<div class="base-rule" aria-hidden="true"></div>

<script is:inline>
  ;(() => {
    'use strict'
    var RM = matchMedia('(prefers-reduced-motion: reduce)').matches
    var doc = document.documentElement
    var els = [].slice.call(document.querySelectorAll('.st'))
    if (!els.length) return

    // Lithophone: gesture-gated WebAudio, no files, works under RM too.
    var AC = null,
      master = null,
      noiseBuf = null
    var scale = [261.63, 293.66, 329.63, 392.0, 440.0, 523.25, 587.33, 659.25]
    var iosUnlocked = false
    function unlockIOSAudio() {
      // iOS mute-switch workaround: a silent WAV once, on first gesture.
      if (iosUnlocked) return
      iosUnlocked = true
      try {
        var a = new Audio(
          'data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAAAAAA=='
        )
        a.setAttribute('playsinline', '')
        a.playsInline = true
        var p = a.play()
        if (p && p.catch) p.catch(function () {})
      } catch (e) {}
    }
    function ensureAudio() {
      unlockIOSAudio()
      if (AC) return
      var A = window.AudioContext || window.webkitAudioContext
      if (!A) return
      try {
        AC = new A()
      } catch (e) {
        return
      }
      master = AC.createGain()
      master.gain.value = 0.5
      master.connect(AC.destination)
      var n = Math.floor(AC.sampleRate * 0.05)
      noiseBuf = AC.createBuffer(1, n, AC.sampleRate)
      var d = noiseBuf.getChannelData(0)
      for (var i = 0; i < n; i++) d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / n, 2)
    }
    function playScheduled(freq) {
      var t = AC.currentTime
      var noise = AC.createBufferSource()
      noise.buffer = noiseBuf
      var bp = AC.createBiquadFilter()
      bp.type = 'bandpass'
      bp.frequency.value = Math.min(4200, freq * 5.5)
      bp.Q.value = 1.2
      var ng = AC.createGain()
      ng.gain.setValueAtTime(0.5, t)
      ng.gain.exponentialRampToValueAtTime(0.0001, t + 0.045)
      noise.connect(bp)
      bp.connect(ng)
      ng.connect(master)
      noise.start(t)
      noise.stop(t + 0.06)

      var osc = AC.createOscillator()
      osc.type = 'sine'
      osc.frequency.setValueAtTime(freq * 1.015, t)
      osc.frequency.exponentialRampToValueAtTime(freq, t + 0.03)
      var lp = AC.createBiquadFilter()
      lp.type = 'lowpass'
      lp.frequency.value = freq * 3
      var og = AC.createGain()
      og.gain.setValueAtTime(0.0001, t)
      og.gain.exponentialRampToValueAtTime(0.32, t + 0.006)
      og.gain.exponentialRampToValueAtTime(0.0001, t + 0.55)
      osc.connect(lp)
      lp.connect(og)
      og.connect(master)
      osc.start(t)
      osc.stop(t + 0.58)
    }
    function strikeNote(freq) {
      if (!AC) return
      // Mobile browsers need resume() to resolve before scheduling sound.
      if (AC.state === 'running') {
        playScheduled(freq)
      } else {
        AC.resume().then(function () {
          if (AC.state === 'running') playScheduled(freq)
        }, function () {})
      }
    }
    document.addEventListener('visibilitychange', function () {
      if (!AC) return
      if (document.hidden) {
        if (AC.state === 'running') AC.suspend()
      } else if (AC.state === 'suspended') {
        AC.resume()
      }
    })

    var stones = null
    function strikeVisual(i) {
      var el = els[i]
      if (stones && stones[i]) {
        stones[i].sq = Math.max(stones[i].sq, 0.16)
        var tapScale = Math.max(1, (stones[i].h || 234) / 234)
        burst(stones[i].cx + stones[i].ox, stones[i].bot, 5, 190 * tapScale, false, tapScale)
        wake()
      } else {
        el.classList.remove('struck')
        void el.offsetWidth
        el.classList.add('struck')
      }
      // Sound and light as one event (hoisted, safe no-op under RM).
      pulseFromLetter(i)
    }
    // Hidden melody: strike E-C-K-S-T-E-I-N in order (either E counts).
    var comboTarget = ['E', 'C', 'K', 'S', 'T', 'E', 'I', 'N']
    var comboIndex = 0
    function comboReward() {
      var grid = document.getElementById('grid-overlay')
      if (grid) {
        grid.classList.add('on')
        setTimeout(function () {
          grid.classList.remove('on')
        }, 900)
      }
      scale.forEach(function (freq, idx) {
        setTimeout(function () {
          strikeNote(freq)
        }, idx * 70)
      })
      if (stones) {
        els.forEach(function (el, idx) {
          setTimeout(function () {
            if (stones[idx]) {
              stones[idx].sq = Math.max(stones[idx].sq, 0.14)
              wake()
            }
          }, idx * 70)
        })
      }
    }
    function checkCombo(i) {
      var letter = els[i].textContent.toUpperCase()
      if (letter === comboTarget[comboIndex]) {
        comboIndex++
        if (comboIndex === comboTarget.length) {
          comboIndex = 0
          comboReward()
        }
      } else {
        comboIndex = letter === comboTarget[0] ? 1 : 0
      }
    }
    // Debounce so one tap (pointerdown + a synthesized click) can't double-strike.
    var lastStrikeAt = new Array(els.length).fill(0)
    function strike(i) {
      var now = performance.now()
      if (now - lastStrikeAt[i] < 400) return
      lastStrikeAt[i] = now
      ensureAudio()
      strikeNote(scale[i])
      strikeVisual(i)
      checkCombo(i)
    }
    els.forEach(function (el, i) {
      el.addEventListener('pointerdown', function (e) {
        e.preventDefault()
        strike(i)
      })
      el.addEventListener('click', function (e) {
        e.preventDefault()
        strike(i)
      })
    })
    document.addEventListener('keydown', function (e) {
      if (e.repeat || e.metaKey || e.ctrlKey || e.altKey) return
      var k = e.key.toLowerCase()
      els.forEach(function (el, i) {
        if (el.textContent.toLowerCase() === k) strike(i)
      })
    })

    // Reduced motion: static constellation only, then skip the rest below.
    if (RM) {
      var rmCv = document.getElementById('dust')
      if (rmCv instanceof HTMLCanvasElement) {
        var rmCtx = rmCv.getContext('2d')
        if (rmCtx) {
          var rmW = innerWidth,
            rmH = innerHeight,
            rmDPR = Math.min(devicePixelRatio || 1, 2)
          rmCv.width = Math.round(rmW * rmDPR)
          rmCv.height = Math.round(rmH * rmDPR)
          rmCtx.setTransform(rmDPR, 0, 0, rmDPR, 0, 0)
          var rmNodes = els.map(function (el) {
            var r = el.getBoundingClientRect()
            return { x: r.left + r.width / 2, y: r.top + r.height / 2 }
          })
          var rmMaxD = Math.min(rmW, rmH) * 0.22
          rmCtx.lineWidth = 1
          for (var ra = 0; ra < rmNodes.length; ra++) {
            for (var rb = ra + 1; rb < rmNodes.length; rb++) {
              var rdx = rmNodes[ra].x - rmNodes[rb].x,
                rdy = rmNodes[ra].y - rmNodes[rb].y
              if (rdx * rdx + rdy * rdy < rmMaxD * rmMaxD) {
                rmCtx.strokeStyle = 'rgba(120,170,150,.06)'
                rmCtx.beginPath()
                rmCtx.moveTo(rmNodes[ra].x, rmNodes[ra].y)
                rmCtx.lineTo(rmNodes[rb].x, rmNodes[rb].y)
                rmCtx.stroke()
              }
            }
          }
        }
      }
      return
    }

    var rowEls = [].slice.call(document.querySelectorAll('.row'))
    var stone = document.getElementById('cornerstone')
    var cv = document.getElementById('dust')
    if (!stone || !cv || !(cv instanceof HTMLCanvasElement)) return
    var ctx = cv.getContext('2d')
    if (!ctx) return

    var W = 0,
      H = 0,
      DPR = 1
    function sizeCv() {
      W = innerWidth
      H = innerHeight
      DPR = Math.min(devicePixelRatio || 1, 2)
      cv.width = Math.round(W * DPR)
      cv.height = Math.round(H * DPR)
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
    }
    sizeCv()

    var cDust = '#a39e93',
      cAcc = '#059669'
    function palette() {
      var s = getComputedStyle(doc)
      cDust = s.getPropertyValue('--dust').trim() || cDust
      cAcc = s.getPropertyValue('--accent-strong').trim() || cAcc
    }
    palette()

    // Letters double as fixed anchor nodes (sampled on settle/resize, never
    // per frame); sparse free nodes fill the rest; thin edges connect near
    // nodes; pulses travel them, including one per strike (above).
    var netNodes = [],
      netEdges = [],
      netPulses = [],
      netBuilt = false,
      netAmbientT = 0,
      nextPulseAt = 1.5 + Math.random() * 1.5
    var glowSprite = (function () {
      var s = 28,
        c = document.createElement('canvas')
      c.width = c.height = s
      var g = c.getContext('2d')
      if (!g) return null
      var grd = g.createRadialGradient(s / 2, s / 2, 0, s / 2, s / 2, s / 2)
      grd.addColorStop(0, 'rgba(255,255,255,.95)')
      grd.addColorStop(1, 'rgba(255,255,255,0)')
      g.fillStyle = grd
      g.fillRect(0, 0, s, s)
      return c
    })()
    function buildNetwork() {
      var perLetter = W < 768 ? 1 : 2
      var anchors = []
      els.forEach(function (el) {
        var r = el.getBoundingClientRect()
        anchors.push({ x: r.left + r.width / 2, y: r.top + r.height / 2, el: el })
        if (perLetter > 1) anchors.push({ x: r.left + r.width * 0.2, y: r.top + r.height * 0.75, el: el })
      })
      // Enough free nodes to read as a full-page network, not a lucky
      // cluster: too few and most land too far apart to draw an edge.
      var cap = W < 768 ? 60 : 240
      var freeN = Math.max(0, cap - anchors.length)
      netNodes = anchors.map(function (a) {
        return { x: a.x, y: a.y, ox: 0, oy: 0, fixed: true, el: a.el, vx: 0, vy: 0, glow: 0 }
      })
      for (var i = 0; i < freeN; i++) {
        netNodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          ox: 0,
          oy: 0,
          fixed: false,
          vx: (Math.random() - 0.5) * 2.2,
          vy: (Math.random() - 0.5) * 2.2,
          glow: 0,
        })
      }
      var maxD = Math.min(W, H) * 0.19
      netEdges = []
      for (var a2 = 0; a2 < netNodes.length; a2++) {
        for (var b2 = a2 + 1; b2 < netNodes.length; b2++) {
          var dx = netNodes[a2].x - netNodes[b2].x,
            dy = netNodes[a2].y - netNodes[b2].y
          if (dx * dx + dy * dy < maxD * maxD) netEdges.push({ a: a2, b: b2 })
        }
      }
      netBuilt = true
    }
    function firePulse(a, b) {
      netPulses.push({ a: a, b: b, t: 0, dur: 0.5 + Math.random() * 0.4 })
    }
    function pulseFromLetter(i) {
      if (!netBuilt || !els[i]) return
      for (var e = 0; e < netEdges.length; e++) {
        var ed = netEdges[e]
        if (netNodes[ed.a].el === els[i]) firePulse(ed.a, ed.b)
        else if (netNodes[ed.b].el === els[i]) firePulse(ed.b, ed.a)
      }
    }

    var delays = [0, 90, 180, 430, 520, 610, 700, 790]
    stones = els.map(function (el, i) {
      return {
        el: el,
        row: i < 3 ? 0 : 1,
        delay: delays[i],
        y: 0,
        v: 0,
        st: 0,
        sq: 0,
        rot: 0,
        vrot: 0,
        restRot: 0,
        tumble: false,
        ox: 0,
        oy: 0,
        tx: 0,
        ty: 0,
        cx: 0,
        cy: 0,
        bot: 0,
        big: false,
        done: false,
      }
    })
    var spin = (Math.random() < 0.5 ? -1 : 1) * (4 + Math.random() * 3)
    var rest = (Math.random() < 0.5 ? -1 : 1) * (0.035 + Math.random() * 0.05)
    var fallen = {
      el: stone,
      row: -1,
      delay: 1120,
      y: 0,
      v: 0,
      st: 0,
      sq: 0,
      rot: 0,
      vrot: spin,
      restRot: rest,
      tumble: true,
      ox: 0,
      oy: 0,
      tx: 0,
      ty: 0,
      cx: 0,
      cy: 0,
      bot: 0,
      big: true,
      done: false,
    }
    stones.push(fallen)
    var rowLeft = [3, 5]

    function measure() {
      stones.forEach(function (s) {
        var r = s.el.getBoundingClientRect()
        s.cx = r.left + r.width / 2
        s.cy = r.top + r.height / 2
        s.bot = r.bottom
        s.h = r.height
      })
    }
    measure()

    var G = 5200,
      REST = 0.24,
      dust = [],
      raf = 0,
      last = 0,
      px = -1,
      py = -1
    var t0 = performance.now() + 280

    function apply(s) {
      var t =
        'translate3d(' +
        s.ox.toFixed(2) +
        'px,' +
        (s.y + s.oy).toFixed(2) +
        'px,0) scale(' +
        (1 + s.sq).toFixed(4) +
        ',' +
        (1 - s.sq).toFixed(4) +
        ')'
      if (s.tumble) t += ' rotate(' + s.rot.toFixed(3) + 'rad)'
      s.el.style.transform = t
    }
    stones.forEach(function (s) {
      s.y = -(s.bot + H * 0.22 + Math.random() * 90)
      apply(s)
    })
    // The stone falls left, near "E", then rolls to its resting corner.
    var baseRuleEl = document.querySelector('.base-rule')
    var leftRef = stones[0]
    if (leftRef) {
      fallen.rollStartOx = leftRef.cx - fallen.cx
      fallen.ox = fallen.rollStartOx
      apply(fallen)
    }
    if (baseRuleEl) baseRuleEl.style.transform = 'scaleX(0)'
    doc.classList.add('anim')

    function burst(x, y, n, pw, acc, scale) {
      scale = scale || 1
      for (var i = 0; i < n; i++) {
        dust.push({
          x: x + (Math.random() - 0.5) * 36 * scale,
          y: y - 2,
          vx: (Math.random() - 0.5) * pw,
          vy: -Math.random() * pw * 0.42 - 30,
          l: 0.38 + Math.random() * 0.5,
          t: 0,
          sz: (1 + Math.random() * 2.4) * scale,
          a: acc && Math.random() < 0.4,
        })
      }
    }
    function boom(s, v) {
      // Scale the splash to the stone's own height, so it still reads next
      // to the much taller one-liner letters instead of vanishing as a speck.
      var scale = Math.max(1, (s.h || 234) / 234)
      var n = Math.round(Math.min(26, 3 + (v - 300) / 110) * Math.min(1.6, scale))
      burst(s.cx + s.ox, s.bot, s.big ? 26 : n, (s.big ? 760 : Math.min(760, v * 0.32)) * scale, s.big, scale)
      s.sq = Math.min(0.02 + v / 26000, 0.09)
    }
    function settle(s) {
      s.v = 0
      s.st = 2
      if (!s.done) {
        s.done = true
        if (s.row >= 0 && --rowLeft[s.row] === 0) rowEls[s.row].classList.add('set')
      }
    }
    function frame(now) {
      raf = 0
      var dt = Math.min(now - last || 16, 40) / 1000
      last = now
      var busy = false,
        i,
        s
      for (i = 0; i < stones.length; i++) {
        s = stones[i]
        if (s.st === 0) {
          busy = true
          if (now >= t0 + s.delay) s.st = 1
        }
        if (s.st === 1) {
          busy = true
          s.v += G * dt
          s.y += s.v * dt
          if (s.tumble) s.rot += s.vrot * dt
          if (s.y >= 0) {
            s.y = 0
            if (!s.done) boom(s, Math.max(s.v, 320))
            if (s.v > 460) {
              s.v = -s.v * REST
              if (s.tumble) s.vrot *= -0.45
            } else if (s.rollStartOx) {
              // Own state (3): stops the fall block above re-triggering.
              s.st = 3
              s.v = 0
              s.vrot = 0
              s.rollT = 0
            } else {
              settle(s)
            }
          }
        }
        if (s.st === 3) {
          busy = true
          s.rollT += dt
          var rollDur = 0.85
          var rp = Math.min(1, s.rollT / rollDur)
          var eased = 1 - Math.pow(1 - rp, 3)
          var newOx = s.rollStartOx * (1 - eased)
          var traveled = s.ox - newOx
          s.ox = newOx
          s.rot += traveled / Math.max(16, s.el.offsetWidth * 0.5)
          if (baseRuleEl) {
            var stoneAbsX = s.cx + s.ox
            baseRuleEl.style.transform = 'scaleX(' + Math.max(0, Math.min(1, stoneAbsX / W)) + ')'
          }
          if (rp >= 1) {
            s.ox = 0
            if (baseRuleEl) baseRuleEl.style.transform = 'scaleX(1)'
            settle(s)
          }
        }
        if (s.sq > 0.0015) {
          s.sq *= Math.exp(-11 * dt)
          busy = true
        } else if (s.sq) s.sq = 0
        if (s.tumble && s.st === 2) {
          var dr = s.restRot - s.rot
          if (Math.abs(dr) > 0.0008 || Math.abs(s.vrot) > 0.01) {
            s.vrot *= Math.exp(-9 * dt)
            s.rot += dr * Math.min(1, 6 * dt)
            busy = true
          } else {
            s.rot = s.restRot
            s.vrot = 0
          }
        }
        if (s.st === 2) {
          if (px >= 0) {
            s.tx = ((px - s.cx) / W) * -9
            s.ty = ((py - s.cy) / H) * -5
          } else {
            s.tx = 0
            s.ty = 0
          }
        }
        if (s.rollStartOx && s.st !== 2) {
          busy = true
        } else {
          var dx = s.tx - s.ox,
            dy = s.ty - s.oy
          if (Math.abs(dx) > 0.04 || Math.abs(dy) > 0.04) {
            var k = Math.min(1, 5.5 * dt)
            s.ox += dx * k
            s.oy += dy * k
            busy = true
          }
        }
        apply(s)
      }
      if (!netBuilt) {
        var allSettled = true
        for (i = 0; i < stones.length; i++) {
          if (stones[i].st !== 2) {
            allSettled = false
            break
          }
        }
        if (allSettled) buildNetwork()
      }
      ctx.clearRect(0, 0, W, H)
      if (dust.length) {
        busy = true
        for (i = dust.length - 1; i >= 0; i--) {
          var p = dust[i]
          p.t += dt
          if (p.t >= p.l) {
            dust.splice(i, 1)
            continue
          }
          p.vy += 1600 * dt
          p.x += p.vx * dt
          p.y += p.vy * dt
          ctx.globalAlpha = (1 - p.t / p.l) * 0.85
          ctx.fillStyle = p.a ? cAcc : cDust
          ctx.fillRect(p.x, p.y, p.sz, p.sz)
        }
        ctx.globalAlpha = 1
      }
      if (netBuilt) {
        for (i = 0; i < netNodes.length; i++) {
          var nd = netNodes[i]
          if (!nd.fixed) {
            nd.x += nd.vx * dt
            nd.y += nd.vy * dt
            if (nd.x < 0) nd.x = W
            else if (nd.x > W) nd.x = 0
            if (nd.y < 0) nd.y = H
            else if (nd.y > H) nd.y = 0
          }
          var tx = 0,
            ty = 0
          if (px >= 0) {
            var pdx = px - nd.x,
              pdy = py - nd.y,
              pd2 = pdx * pdx + pdy * pdy,
              rad = 150
            if (pd2 < rad * rad) {
              var pd = Math.sqrt(pd2) || 1,
                infl = 1 - pd / rad
              tx = (-pdx / pd) * infl * 6
              ty = (-pdy / pd) * infl * 6
              nd.glow = Math.min(1, nd.glow + infl * 0.06)
            }
          }
          nd.ox += (tx - nd.ox) * Math.min(1, 4 * dt)
          nd.oy += (ty - nd.oy) * Math.min(1, 4 * dt)
          nd.glow *= Math.exp(-2.5 * dt)
        }
        ctx.lineWidth = 1
        for (i = 0; i < netEdges.length; i++) {
          var ed = netEdges[i],
            n1 = netNodes[ed.a],
            n2 = netNodes[ed.b]
          ctx.strokeStyle = 'rgba(120,170,150,' + (0.09 + Math.max(n1.glow, n2.glow) * 0.07).toFixed(3) + ')'
          ctx.beginPath()
          ctx.moveTo(n1.x + n1.ox, n1.y + n1.oy)
          ctx.lineTo(n2.x + n2.ox, n2.y + n2.oy)
          ctx.stroke()
        }
        for (i = 0; i < netNodes.length; i++) {
          var nd2 = netNodes[i]
          ctx.globalAlpha = 0.15 + nd2.glow * 0.4
          ctx.fillStyle = cAcc
          ctx.fillRect(nd2.x + nd2.ox - 0.6, nd2.y + nd2.oy - 0.6, 1.2, 1.2)
        }
        ctx.globalAlpha = 1
        if (glowSprite) {
          for (i = netPulses.length - 1; i >= 0; i--) {
            var pu = netPulses[i]
            pu.t += dt
            if (pu.t >= pu.dur) {
              netPulses.splice(i, 1)
              continue
            }
            var pp = pu.t / pu.dur,
              pa = netNodes[pu.a],
              pb = netNodes[pu.b],
              ppx = pa.x + pa.ox + (pb.x + pb.ox - pa.x - pa.ox) * pp,
              ppy = pa.y + pa.oy + (pb.y + pb.oy - pa.y - pa.oy) * pp,
              fade = pp < 0.5 ? pp * 2 : (1 - pp) * 2
            ctx.globalAlpha = fade * 0.8
            ctx.drawImage(glowSprite, ppx - 7, ppy - 7, 14, 14)
          }
          ctx.globalAlpha = 1
        }
        netAmbientT += dt
        if (netAmbientT > nextPulseAt && netEdges.length) {
          netAmbientT = 0
          nextPulseAt = 1.2 + Math.random() * 1.8
          var re = netEdges[(Math.random() * netEdges.length) | 0]
          firePulse(re.a, re.b)
        }
        busy = true
      }
      if (busy) raf = requestAnimationFrame(frame)
    }
    function wake() {
      if (!raf && !document.hidden) {
        last = performance.now()
        raf = requestAnimationFrame(frame)
      }
    }
    wake()

    addEventListener(
      'pointermove',
      function (e) {
        px = e.clientX
        py = e.clientY
        wake()
      },
      { passive: true }
    )
    document.addEventListener('pointerleave', function () {
      px = py = -1
      wake()
    })
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        if (raf) {
          cancelAnimationFrame(raf)
          raf = 0
        }
      } else wake()
    })
    var rt = 0
    addEventListener('resize', function () {
      clearTimeout(rt)
      rt = setTimeout(function () {
        sizeCv()
        if (netBuilt) buildNetwork()
        var allDone = stones.every(function (s) {
          return s.st === 2
        })
        if (allDone) {
          stones.forEach(function (s) {
            s.el.style.transform = ''
            s.ox = s.oy = s.tx = s.ty = 0
            s.rot = s.tumble ? s.restRot : 0
          })
          measure()
          stones.forEach(apply)
        }
        wake()
      }, 160)
    })
  })()
</script>
