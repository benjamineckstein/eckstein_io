---
/**
 * The kinetic poster hero: giant staggered ECK / STEIN letters that drop,
 * overshoot and settle, plus the dust-particle canvas and the fallen-stone
 * physics that also carries the BaseLayout cornerstone button into its
 * resting corner. Shared between the DE and EN landing pages so the entrance
 * choreography only has to be written, and tuned, once.
 *
 * Under prefers-reduced-motion (or with JS disabled) the script below never
 * runs: letters, the cornerstone and the baseline rule simply render in
 * their final CSS position, no animation, fully readable immediately.
 */
---

<canvas id="dust" aria-hidden="true"></canvas>
<div class="mid">
  <h1 class="rows" aria-label="Benjamin Eckstein">
    <span class="row" aria-hidden="true">
      <span class="st">E</span><span class="st">C</span><span class="st">K</span>
    </span>
    <span class="row" aria-hidden="true">
      <span class="st">S</span><span class="st">T</span><span class="st">E</span><span class="st">I</span><span
        class="st">N</span
      >
    </span>
    <span class="dict serif" aria-hidden="true" lang="de">der; -s, -e</span>
  </h1>
  <slot />
</div>
<div class="base-rule" aria-hidden="true"></div>

<script is:inline>
  ;(() => {
    'use strict'
    var RM = matchMedia('(prefers-reduced-motion: reduce)').matches
    var doc = document.documentElement
    var els = [].slice.call(document.querySelectorAll('.st'))
    if (!els.length) return

    // ---- The lithophone: click or tap a letter to strike it. WebAudio
    // only, no audio files. Strictly gesture-gated: the AudioContext is
    // created on the first strike, never on load, and is suspended when
    // the tab is hidden. Works even under reduced motion (sound is
    // user-initiated); only the visual response changes, see strikeVisual. ----
    var AC = null,
      master = null,
      noiseBuf = null
    var scale = [261.63, 293.66, 329.63, 392.0, 440.0, 523.25, 587.33, 659.25]
    var iosUnlocked = false
    function unlockIOSAudio() {
      // The classic mute-switch workaround: play a ~1s silent WAV through
      // an HTML5 audio element once, on the first real gesture. This
      // promotes the iOS audio session to playback so WebAudio stays
      // audible even with the ring switch on silent. Never runs on load,
      // never autoplays: only ever called from inside a strike.
      if (iosUnlocked) return
      iosUnlocked = true
      try {
        var a = new Audio(
          'data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAAAAAA=='
        )
        a.setAttribute('playsinline', '')
        a.playsInline = true
        var p = a.play()
        if (p && p.catch) p.catch(function () {})
      } catch (e) {}
    }
    function ensureAudio() {
      unlockIOSAudio()
      if (AC) return
      var A = window.AudioContext || window.webkitAudioContext
      if (!A) return
      try {
        AC = new A()
      } catch (e) {
        return
      }
      master = AC.createGain()
      master.gain.value = 0.5
      master.connect(AC.destination)
      var n = Math.floor(AC.sampleRate * 0.05)
      noiseBuf = AC.createBuffer(1, n, AC.sampleRate)
      var d = noiseBuf.getChannelData(0)
      for (var i = 0; i < n; i++) d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / n, 2)
    }
    function playScheduled(freq) {
      var t = AC.currentTime
      var noise = AC.createBufferSource()
      noise.buffer = noiseBuf
      var bp = AC.createBiquadFilter()
      bp.type = 'bandpass'
      bp.frequency.value = Math.min(4200, freq * 5.5)
      bp.Q.value = 1.2
      var ng = AC.createGain()
      ng.gain.setValueAtTime(0.5, t)
      ng.gain.exponentialRampToValueAtTime(0.0001, t + 0.045)
      noise.connect(bp)
      bp.connect(ng)
      ng.connect(master)
      noise.start(t)
      noise.stop(t + 0.06)

      var osc = AC.createOscillator()
      osc.type = 'sine'
      osc.frequency.setValueAtTime(freq * 1.015, t)
      osc.frequency.exponentialRampToValueAtTime(freq, t + 0.03)
      var lp = AC.createBiquadFilter()
      lp.type = 'lowpass'
      lp.frequency.value = freq * 3
      var og = AC.createGain()
      og.gain.setValueAtTime(0.0001, t)
      og.gain.exponentialRampToValueAtTime(0.32, t + 0.006)
      og.gain.exponentialRampToValueAtTime(0.0001, t + 0.55)
      osc.connect(lp)
      lp.connect(og)
      og.connect(master)
      osc.start(t)
      osc.stop(t + 0.58)
    }
    function strikeNote(freq) {
      if (!AC) return
      // Some mobile browsers (notably iOS Safari) create the context
      // suspended even inside a gesture and need resume() to actually
      // resolve before scheduling sound; resume() is a promise, so the
      // note has to wait for it rather than checking state right after
      // firing it (which desktop Chrome tolerates by resolving eagerly,
      // masking this on desktop while staying silent on mobile).
      if (AC.state === 'running') {
        playScheduled(freq)
      } else {
        AC.resume().then(function () {
          if (AC.state === 'running') playScheduled(freq)
        }, function () {})
      }
    }
    document.addEventListener('visibilitychange', function () {
      if (!AC) return
      if (document.hidden) {
        if (AC.state === 'running') AC.suspend()
      } else if (AC.state === 'suspended') {
        AC.resume()
      }
    })

    // `stones` stays null until (if) the entrance physics below sets it up;
    // strikeVisual falls back to a plain CSS tick otherwise (no physics,
    // or reduced motion).
    var stones = null
    function strikeVisual(i) {
      var el = els[i]
      if (stones && stones[i]) {
        stones[i].sq = Math.max(stones[i].sq, 0.16)
        burst(stones[i].cx + stones[i].ox, stones[i].bot, 5, 190, false)
        wake()
      } else {
        el.classList.remove('struck')
        void el.offsetWidth
        el.classList.add('struck')
      }
    }
    // Hidden melody easter egg: strike the letters in the name's own order,
    // E-C-K-S-T-E-I-N (either E counts), and the poster answers back. No
    // hint anywhere on the page, discoverable only.
    var comboTarget = ['E', 'C', 'K', 'S', 'T', 'E', 'I', 'N']
    var comboIndex = 0
    function comboReward() {
      var grid = document.getElementById('grid-overlay')
      if (grid) {
        grid.classList.add('on')
        setTimeout(function () {
          grid.classList.remove('on')
        }, 900)
      }
      scale.forEach(function (freq, idx) {
        setTimeout(function () {
          strikeNote(freq)
        }, idx * 70)
      })
      if (stones) {
        els.forEach(function (el, idx) {
          setTimeout(function () {
            if (stones[idx]) {
              stones[idx].sq = Math.max(stones[idx].sq, 0.14)
              wake()
            }
          }, idx * 70)
        })
      }
    }
    function checkCombo(i) {
      var letter = els[i].textContent.toUpperCase()
      if (letter === comboTarget[comboIndex]) {
        comboIndex++
        if (comboIndex === comboTarget.length) {
          comboIndex = 0
          comboReward()
        }
      } else {
        comboIndex = letter === comboTarget[0] ? 1 : 0
      }
    }
    // Guards a single physical tap from firing twice (pointerdown plus a
    // synthesized click some browsers still deliver despite the
    // preventDefault below) without blocking legitimate fast, distinct
    // taps the melody sequence needs.
    var lastStrikeAt = new Array(els.length).fill(0)
    function strike(i) {
      var now = performance.now()
      if (now - lastStrikeAt[i] < 400) return
      lastStrikeAt[i] = now
      // ensureAudio()/strikeNote() must run synchronously from here, inside
      // the real user gesture, so the browser still counts this as
      // activated even though strikeNote's own resume chain finishes async.
      ensureAudio()
      strikeNote(scale[i])
      strikeVisual(i)
      checkCombo(i)
    }
    els.forEach(function (el, i) {
      el.addEventListener('pointerdown', function (e) {
        e.preventDefault()
        strike(i)
      })
      el.addEventListener('click', function (e) {
        e.preventDefault()
        strike(i)
      })
    })
    document.addEventListener('keydown', function (e) {
      if (e.repeat || e.metaKey || e.ctrlKey || e.altKey) return
      var k = e.key.toLowerCase()
      els.forEach(function (el, i) {
        if (el.textContent.toLowerCase() === k) strike(i)
      })
    })

    // Reduced motion (or a user who got here before fonts/JS settled): leave
    // the static, already-correct CSS layout alone. No 'anim' class means
    // none of the entrance transforms below ever apply. The lithophone
    // above still works either way.
    if (RM) return

    var rowEls = [].slice.call(document.querySelectorAll('.row'))
    var stone = document.getElementById('cornerstone')
    var cv = document.getElementById('dust')
    if (!stone || !cv || !(cv instanceof HTMLCanvasElement)) return
    var ctx = cv.getContext('2d')
    if (!ctx) return

    var W = 0,
      H = 0,
      DPR = 1
    function sizeCv() {
      W = innerWidth
      H = innerHeight
      DPR = Math.min(devicePixelRatio || 1, 2)
      cv.width = Math.round(W * DPR)
      cv.height = Math.round(H * DPR)
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
    }
    sizeCv()

    var cDust = '#a39e93',
      cAcc = '#059669'
    function palette() {
      var s = getComputedStyle(doc)
      cDust = s.getPropertyValue('--dust').trim() || cDust
      cAcc = s.getPropertyValue('--accent-strong').trim() || cAcc
    }
    palette()

    // Ambient background: sparse, slow-drifting sediment behind the poster,
    // reusing the entrance dust palette at a fraction of its opacity. Never
    // stops (wraps at the edges instead of expiring) so the frame loop, and
    // document.hidden pause, run forever once seeded; kept sparse and cheap
    // to stay well under 60fps budget and never compete with the text.
    var ambient = []
    function seedAmbient() {
      var n = Math.max(6, Math.min(28, Math.round((W * H) / 130000)))
      ambient = []
      for (var i = 0; i < n; i++) {
        ambient.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 3,
          vy: -2 - Math.random() * 3,
          sz: 0.6 + Math.random() * 1.1,
          a: 0.035 + Math.random() * 0.045,
        })
      }
    }
    seedAmbient()

    var delays = [0, 90, 180, 430, 520, 610, 700, 790]
    stones = els.map(function (el, i) {
      return {
        el: el,
        row: i < 3 ? 0 : 1,
        delay: delays[i],
        y: 0,
        v: 0,
        st: 0,
        sq: 0,
        rot: 0,
        vrot: 0,
        restRot: 0,
        tumble: false,
        ox: 0,
        oy: 0,
        tx: 0,
        ty: 0,
        cx: 0,
        cy: 0,
        bot: 0,
        big: false,
        done: false,
      }
    })
    // The one idea borrowed from the wildcard prototype: this single stone
    // tumbles (gains rotation) as it falls, unlike the letters above it.
    var spin = (Math.random() < 0.5 ? -1 : 1) * (4 + Math.random() * 3)
    var rest = (Math.random() < 0.5 ? -1 : 1) * (0.035 + Math.random() * 0.05)
    var fallen = {
      el: stone,
      row: -1,
      delay: 1120,
      y: 0,
      v: 0,
      st: 0,
      sq: 0,
      rot: 0,
      vrot: spin,
      restRot: rest,
      tumble: true,
      ox: 0,
      oy: 0,
      tx: 0,
      ty: 0,
      cx: 0,
      cy: 0,
      bot: 0,
      big: true,
      done: false,
    }
    stones.push(fallen)
    var rowLeft = [3, 5]

    function measure() {
      stones.forEach(function (s) {
        var r = s.el.getBoundingClientRect()
        s.cx = r.left + r.width / 2
        s.cy = r.top + r.height / 2
        s.bot = r.bottom
      })
    }
    measure()

    var G = 5200,
      REST = 0.24,
      dust = [],
      raf = 0,
      last = 0,
      px = -1,
      py = -1
    var t0 = performance.now() + 280

    function apply(s) {
      var t =
        'translate3d(' +
        s.ox.toFixed(2) +
        'px,' +
        (s.y + s.oy).toFixed(2) +
        'px,0) scale(' +
        (1 + s.sq).toFixed(4) +
        ',' +
        (1 - s.sq).toFixed(4) +
        ')'
      if (s.tumble) t += ' rotate(' + s.rot.toFixed(3) + 'rad)'
      s.el.style.transform = t
    }
    stones.forEach(function (s) {
      s.y = -(s.bot + H * 0.22 + Math.random() * 90)
      apply(s)
    })
    // The rolling stone: falls straight down on the left, near the first
    // letter, same as the other stones; once it lands it rolls along the
    // floor to its resting corner instead of settling in place. Uses the
    // "E" stone's pre-transform measurement (from measure(), above) for
    // the horizontal start, since it is otherwise about to fall too.
    var baseRuleEl = document.querySelector('.base-rule')
    var leftRef = stones[0]
    if (leftRef) {
      fallen.rollStartOx = leftRef.cx - fallen.cx
      fallen.ox = fallen.rollStartOx
      apply(fallen)
    }
    if (baseRuleEl) baseRuleEl.style.transform = 'scaleX(0)'
    doc.classList.add('anim')

    function burst(x, y, n, pw, acc) {
      for (var i = 0; i < n; i++) {
        dust.push({
          x: x + (Math.random() - 0.5) * 36,
          y: y - 2,
          vx: (Math.random() - 0.5) * pw,
          vy: -Math.random() * pw * 0.42 - 30,
          l: 0.38 + Math.random() * 0.5,
          t: 0,
          sz: 1 + Math.random() * 2.4,
          a: acc && Math.random() < 0.4,
        })
      }
    }
    function boom(s, v) {
      var n = Math.round(Math.min(26, 3 + (v - 300) / 110))
      burst(s.cx + s.ox, s.bot, s.big ? 26 : n, s.big ? 760 : Math.min(760, v * 0.32), s.big)
      s.sq = Math.min(0.02 + v / 26000, 0.09)
    }
    function settle(s) {
      s.v = 0
      s.st = 2
      if (!s.done) {
        s.done = true
        if (s.row >= 0 && --rowLeft[s.row] === 0) rowEls[s.row].classList.add('set')
      }
    }
    function frame(now) {
      raf = 0
      var dt = Math.min(now - last || 16, 40) / 1000
      last = now
      var busy = false,
        i,
        s
      for (i = 0; i < stones.length; i++) {
        s = stones[i]
        if (s.st === 0) {
          busy = true
          if (now >= t0 + s.delay) s.st = 1
        }
        if (s.st === 1) {
          busy = true
          s.v += G * dt
          s.y += s.v * dt
          if (s.tumble) s.rot += s.vrot * dt
          if (s.y >= 0) {
            s.y = 0
            // Every letter kicks up dust the first time it lands, hard
            // bounce or soft: only the bounce-vs-settle branch depends on
            // velocity, the dust puff itself does not.
            if (!s.done) boom(s, Math.max(s.v, 320))
            if (s.v > 460) {
              s.v = -s.v * REST
              if (s.tumble) s.vrot *= -0.45
            } else if (s.rollStartOx) {
              // Rolling is its own state (3), distinct from falling (1),
              // so this vertical-fall block stops running entirely for
              // the rest of the roll: gravity must not keep integrating
              // s.v/s.y underneath it, or it re-triggers "impact" (and
              // another bounce/dust burst) every subsequent frame.
              s.st = 3
              s.v = 0
              s.vrot = 0
              s.rollT = 0
            } else {
              settle(s)
            }
          }
        }
        if (s.st === 3) {
          busy = true
          s.rollT += dt
          var rollDur = 0.85
          var rp = Math.min(1, s.rollT / rollDur)
          var eased = 1 - Math.pow(1 - rp, 3)
          var newOx = s.rollStartOx * (1 - eased)
          var traveled = s.ox - newOx
          s.ox = newOx
          // Rotation proportional to distance traveled, so it reads as
          // rolling rather than sliding.
          s.rot += traveled / Math.max(16, s.el.offsetWidth * 0.5)
          if (baseRuleEl) {
            var stoneAbsX = s.cx + s.ox
            baseRuleEl.style.transform = 'scaleX(' + Math.max(0, Math.min(1, stoneAbsX / W)) + ')'
          }
          if (rp >= 1) {
            s.ox = 0
            if (baseRuleEl) baseRuleEl.style.transform = 'scaleX(1)'
            settle(s)
          }
        }
        if (s.sq > 0.0015) {
          s.sq *= Math.exp(-11 * dt)
          busy = true
        } else if (s.sq) s.sq = 0
        if (s.tumble && s.st === 2) {
          var dr = s.restRot - s.rot
          if (Math.abs(dr) > 0.0008 || Math.abs(s.vrot) > 0.01) {
            s.vrot *= Math.exp(-9 * dt)
            s.rot += dr * Math.min(1, 6 * dt)
            busy = true
          } else {
            s.rot = s.restRot
            s.vrot = 0
          }
        }
        if (s.st === 2) {
          if (px >= 0) {
            s.tx = ((px - s.cx) / W) * -9
            s.ty = ((py - s.cy) / H) * -5
          } else {
            s.tx = 0
            s.ty = 0
          }
        }
        // The rolling stone's horizontal position is fully owned by the
        // fall-then-roll logic above until it settles; the generic
        // pointer-parallax easing below only takes over once it does.
        if (s.rollStartOx && s.st !== 2) {
          busy = true
        } else {
          var dx = s.tx - s.ox,
            dy = s.ty - s.oy
          if (Math.abs(dx) > 0.04 || Math.abs(dy) > 0.04) {
            var k = Math.min(1, 5.5 * dt)
            s.ox += dx * k
            s.oy += dy * k
            busy = true
          }
        }
        apply(s)
      }
      ctx.clearRect(0, 0, W, H)
      if (dust.length) {
        busy = true
        for (i = dust.length - 1; i >= 0; i--) {
          var p = dust[i]
          p.t += dt
          if (p.t >= p.l) {
            dust.splice(i, 1)
            continue
          }
          p.vy += 1600 * dt
          p.x += p.vx * dt
          p.y += p.vy * dt
          ctx.globalAlpha = (1 - p.t / p.l) * 0.85
          ctx.fillStyle = p.a ? cAcc : cDust
          ctx.fillRect(p.x, p.y, p.sz, p.sz)
        }
        ctx.globalAlpha = 1
      }
      for (i = 0; i < ambient.length; i++) {
        var m = ambient[i]
        m.x += m.vx * dt
        m.y += m.vy * dt
        if (m.x < -4) m.x = W + 4
        else if (m.x > W + 4) m.x = -4
        if (m.y < -4) m.y = H + 4
        else if (m.y > H + 4) m.y = -4
        ctx.globalAlpha = m.a
        ctx.fillStyle = cDust
        ctx.fillRect(m.x, m.y, m.sz, m.sz)
      }
      ctx.globalAlpha = 1
      if (busy || ambient.length) raf = requestAnimationFrame(frame)
    }
    function wake() {
      if (!raf && !document.hidden) {
        last = performance.now()
        raf = requestAnimationFrame(frame)
      }
    }
    wake()

    addEventListener(
      'pointermove',
      function (e) {
        px = e.clientX
        py = e.clientY
        wake()
      },
      { passive: true }
    )
    document.addEventListener('pointerleave', function () {
      px = py = -1
      wake()
    })
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        if (raf) {
          cancelAnimationFrame(raf)
          raf = 0
        }
      } else wake()
    })
    var rt = 0
    addEventListener('resize', function () {
      clearTimeout(rt)
      rt = setTimeout(function () {
        sizeCv()
        seedAmbient()
        var allDone = stones.every(function (s) {
          return s.st === 2
        })
        if (allDone) {
          stones.forEach(function (s) {
            s.el.style.transform = ''
            s.ox = s.oy = s.tx = s.ty = 0
            s.rot = s.tumble ? s.restRot : 0
          })
          measure()
          stones.forEach(apply)
        }
        wake()
      }, 160)
    })
  })()
</script>
