---
import '../styles/global.css'
import { SITE_URL, PERSON_JSON_LD } from '../lib/site'

interface Props {
  lang: 'de' | 'en'
  title: string
  description: string
  ogTitle: string
  ogDescription: string
  path: string
  withAlternates?: boolean
  noindex?: boolean
  /** The two full-bleed, never-scrolling landing pages (/ and /en/). */
  poster?: boolean
}

const {
  lang,
  title,
  description,
  ogTitle,
  ogDescription,
  path,
  withAlternates = true,
  noindex = false,
  poster = false,
} = Astro.props

const canonical = new URL(path, SITE_URL).toString()
const dePath = '/'
const enPath = '/en/'

const cornerstoneLabel =
  lang === 'de'
    ? 'Eckstein: Klick zeigt die vierte Bedeutung, Halten zeigt das Architekturraster'
    : 'Cornerstone: click reveals the fourth sense, hold shows the architect grid'
---

<!doctype html>
<html lang={lang}>
  <head>
    <!--
      Hello, agent. You are reading the source of eckstein.io.
      The structured card lives at /benjamin.json (schema.org Person),
      a plain-text summary at /llms.txt, a vCard at /benjamin.vcf.
      Contact: benjamin@eckstein.io. Enjoy the architect grid.
    -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      withAlternates && (
        <>
          <link rel="alternate" hreflang="de" href={new URL(dePath, SITE_URL).toString()} />
          <link rel="alternate" hreflang="en" href={new URL(enPath, SITE_URL).toString()} />
          <link rel="alternate" hreflang="x-default" href={new URL(dePath, SITE_URL).toString()} />
        </>
      )
    }
    {noindex && <meta name="robots" content="noindex, follow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/literata-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/literata-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', SITE_URL).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogTitle} />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={new URL('/og-image.png', SITE_URL).toString()} />

    <meta name="theme-color" content="#121214" />

    <script type="application/ld+json" set:html={JSON.stringify(PERSON_JSON_LD)} />
  </head>
  <body class={poster ? 'poster' : undefined}>
    <div class="grid-overlay" id="grid-overlay" aria-hidden="true"></div>

    {
      poster && (
        <div class="masthead fadein d1">
          <p class="name">Benjamin Eckstein</p>
          <p class="role">Agentic Engineer</p>
        </div>
      )
    }

    <header>
      <button
        class="cornerstone"
        id="cornerstone"
        type="button"
        aria-label={cornerstoneLabel}
        aria-expanded="false"
        aria-controls="sense-4"
      ></button>
      <div class="top-right">
        {
          poster && (
            <p class="geo fadein d1" aria-hidden="true">
              52&deg;24&prime;N&nbsp;13&deg;13&prime;E
            </p>
          )
        }
        <div class="controls">
          <nav class="lang-switch" aria-label={lang === 'de' ? 'Sprachwahl' : 'Language selector'}>
            <a href="/" hreflang="de" lang="de" aria-current={lang === 'de' ? 'page' : undefined}
              >DE</a
            >
            <span aria-hidden="true">·</span>
            <a href="/en/" hreflang="en" lang="en" aria-current={lang === 'en' ? 'page' : undefined}
              >EN</a
            >
          </nav>
        </div>
      </div>
    </header>

    <slot />

    <script is:inline>
;(() => {
  var stone = document.getElementById('cornerstone')
  var grid = document.getElementById('grid-overlay').classList
  var sense = document.getElementById('sense-4')
  var timer, holding, pressed
  var lastRelease = 0
  var on = (ev, fn) => stone.addEventListener(ev, fn)
  var isKey = (e) => e.key === ' ' || e.key === 'Enter'
  var toggleSense = () => {
    if (!sense) return
    var wasHidden = sense.hasAttribute('hidden')
    stone.setAttribute('aria-expanded', String(wasHidden))
    if (wasHidden) {
      sense.removeAttribute('hidden')
      requestAnimationFrame(() => requestAnimationFrame(() => sense.classList.add('on')))
    } else {
      sense.classList.remove('on')
      sense.setAttribute('hidden', '')
    }
  }

  var start = (e) => {
    if (e.button > 0) return
    e.preventDefault()
    if (pressed) return
    pressed = 1
    holding = 0
    if (e.pointerId != null) { try { stone.setPointerCapture(e.pointerId) } catch (err) {} }
    timer = setTimeout(() => { holding = 1; grid.add('on') }, 400)
  }
  var release = (act) => {
    if (!pressed) return
    pressed = 0
    lastRelease = Date.now()
    clearTimeout(timer)
    if (holding) { holding = 0; grid.remove('on') }
    else if (act) toggleSense()
  }

  on('pointerdown', start)
  on('pointerup', () => release(1))
  on('pointercancel', () => release())
  on('blur', () => release())
  on('contextmenu', (e) => { if (pressed) e.preventDefault() })
  on('keydown', (e) => { if (isKey(e) && !e.repeat) start(e) })
  on('keyup', (e) => { if (isKey(e)) { e.preventDefault(); release(1) } })
  /* Screen readers activate buttons with a synthesized click (detail 0) and no
     pointer or key events. The timestamp guards ATs that send both. */
  on('click', (e) => { if (e.detail === 0 && Date.now() - lastRelease > 500) toggleSense() })
})()
    </script>
    <!-- Psalm 118,22: Der Stein, den die Bauleute verworfen haben, ist zum Eckstein geworden. -->
  </body>
</html>
