---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import Footer from '../../components/Footer.astro'
import { CODEWITHAGENTS_EN_URL, KI_SYNDIKAT_URL, CONTACT_EMAIL } from '../../lib/site'
---

<BaseLayout
  lang="en"
  title="Eckstein, der | Benjamin Eckstein"
  description="Eckstein, der: Benjamin Eckstein, agentic engineer near Berlin. Has written software for twenty years, now Benjamin teaches machines to do the same."
  ogTitle="Eck·stein, der"
  ogDescription="A dictionary entry for a name that became a foundation."
  path="/en/"
  poster
>
  <main class="entry">
    <Hero>
      <p class="tag serif fadein d2">
        Has written software for twenty years. Now Benjamin teaches machines to do the same.
      </p>
      <p id="sense-4" class="psalm serif" hidden>
        <span class="sense-label">‹biblical›</span> the stone the builders rejected; it has become
        the cornerstone <span class="sense-label">‹Psalm 118:22›</span>
      </p>
    </Hero>
    <nav class="links" aria-label="Links">
      <a class="link fadein d3" href={CODEWITHAGENTS_EN_URL}>
        <span class="idx">01</span><span>codewithagents.de</span><span class="hint serif"
          >Work, Blog, OSS</span
        >
      </a>
      <a class="link fadein d4" href={KI_SYNDIKAT_URL}>
        <span class="idx">02</span><span>ki-syndikat.de</span><span class="hint serif"
          >Community, Co-founder</span
        >
      </a>
      <a class="link fadein d5" href={`mailto:${CONTACT_EMAIL}`}>
        <span class="idx">03</span><span>{CONTACT_EMAIL}</span><span class="hint serif"
          >Contact</span
        >
      </a>
    </nav>
  </main>
  <Footer lang="en" />
</BaseLayout>
